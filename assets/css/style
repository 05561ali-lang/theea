
body{font-family:Arial;margin:0;background:#fafafa}

.header{
display:flex;
justify-content:space-between;
padding:16px;
background:#111;
color:white;
}

.product-grid{
display:grid;
grid-template-columns:repeat(4,1fr);
gap:20px;
padding:40px;
}

.product-card{
background:white;
padding:20px;
border:1px solid #eee;
}

.footer{
background:#111;
color:white;
text-align:center;
padding:20px;
}
